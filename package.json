{
  "name": "aicoder",
  "version": "0.1.0",
  "description": "AI pair-programming desktop editor focused on .NET and Azure workflows.",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc -b && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
